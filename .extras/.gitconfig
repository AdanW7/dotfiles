# This is Git's per-user configuration file.
[user]
# Please adapt and uncomment the following lines:
	name = adan
[core]
    pager = delta
    editor = nvim
    autocrlf = input
    fsmonitor = true
    untrackedCache = true
    excludesfile = "~/.gitignore_global"

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true
    dark = true
    line-numbers = true
    ; side-by-side = true

[merge]
    conflictStyle = zdiff3

[diff]
    submodule = log

[fetch]
    prune = true
    prunetags = true

[push]
    autoSetupRemote = true
    followTags = true
[rebase]
    autoStash = true
    autoSquash = true

[branch]
    sort = -committerdate
[help]
    autocorrect = prompt
[init]
    defaultBranch = main
[pull]
    rebase = true

[log]
    date = relative
    abbrevCommit = true
[commit]
    verbose = true

[stash]
    showPatch = true

[tag]
    sort = -version:refname

[grep]
    lineNumber = true
    patternType = perl
[status]
    showUntrackedFiles = all
    submoduleSummary = true

[alias]
    lg = log --oneline --graph --decorate --all
    st = status -sb
    undo = reset --soft HEAD~1

[diff]
    algorithm = histogram
